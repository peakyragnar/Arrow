<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Arrow · {{ summary.ticker }} coverage</title>
  <link rel="stylesheet" href="/static/dashboard.css">
</head>
<body>

<header class="topbar">
  <div class="brand">Arrow</div>
  <nav class="topnav">
    <a href="/findings?status=open" class="navlink">Findings</a>
    <a href="/coverage" class="navlink current">Coverage</a>
  </nav>
  <form class="ticker-select" method="get" action="/">
    <label for="ticker-dropdown">Ticker:</label>
    <select id="ticker-dropdown" onchange="window.location.href = '/t/' + this.value;">
      <option value="">— pick —</option>
      {% for t in tickers %}
        <option value="{{ t }}" {% if t == summary.ticker %}selected{% endif %}>{{ t }}</option>
      {% endfor %}
    </select>
  </form>
</header>

<main class="finding-detail">
  <a class="back" href="/coverage">← back to coverage matrix</a>

  <h1>
    <span>{{ summary.ticker }}</span>
    <span class="type">{{ summary.name }}</span>
  </h1>

  <section class="status-block">
    <h2>Tracking</h2>
    <table class="kv">
      <tr><th>Seeded at</th><td>{{ summary.seeded_at }}</td></tr>
    </table>
  </section>

  <section class="status-block">
    <h2>Vertical summary</h2>
    <table class="coverage-matrix inline">
      <thead>
        <tr>
          <th>Vertical</th>
          <th>Has data</th>
          <th>Periods</th>
          <th>Rows</th>
          <th>Earliest</th>
          <th>Latest</th>
        </tr>
      </thead>
      <tbody>
        {% for v in verticals %}
          {% set cell = summary.by_vertical[v] %}
          <tr>
            <td><strong>{{ v }}</strong></td>
            <td class="cov-cell {% if cell.has_data %}cov-yes{% else %}cov-no{% endif %}">
              {% if cell.has_data %}<span class="check">✓</span>{% else %}<span class="cross">—</span>{% endif %}
            </td>
            <td>{{ cell.period_count }}</td>
            <td>{{ cell.row_count }}</td>
            <td>{{ cell.earliest or '—' }}</td>
            <td>{{ cell.latest or '—' }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  {% for v in verticals %}
    {% set rows = per_vertical[v] %}
    {% if rows %}
      <section class="vertical-detail">
        <h2>{{ v }} — {{ rows | length }} period{{ '' if rows|length == 1 else 's' }}</h2>
        <table class="findings-table">
          <thead>
            <tr>
              {% if v in ('financials', 'segments', 'employees') %}
                <th>Period end</th>
                <th>Type</th>
                <th>Fiscal label</th>
                <th>Rows</th>
              {% else %}
                <th>Type</th>
                <th>Period</th>
                <th>Period end</th>
                <th>Accession</th>
                <th>Published</th>
              {% endif %}
            </tr>
          </thead>
          <tbody>
            {% for r in rows[:50] %}
              <tr>
                {% if v in ('financials', 'segments', 'employees') %}
                  <td>{{ r.period_end }}</td>
                  <td>{{ r.period_type }}</td>
                  <td>{{ r.fiscal_period_label }}</td>
                  <td>{{ r.rows }}</td>
                {% else %}
                  <td>{{ r.artifact_type }}</td>
                  <td>{{ r.fiscal_period_key or '—' }}</td>
                  <td>{{ r.period_end or '—' }}</td>
                  <td><code>{{ r.accession_number or '—' }}</code></td>
                  <td>{{ r.published_at }}</td>
                {% endif %}
              </tr>
            {% endfor %}
          </tbody>
        </table>
        {% if rows | length > 50 %}
          <p class="hint">Showing 50 of {{ rows | length }}.</p>
        {% endif %}
      </section>
    {% endif %}
  {% endfor %}

  {# V1.2: no Remove button. Every ticker in `companies` is tracked
     by default; to stop tracking, suppress findings (common path)
     or delete from companies (rare, blocked by FK constraints
     while the ticker has data). #}
</main>

<footer class="bottom">
  <a href="/coverage">coverage matrix</a> &middot;
  <a href="/findings?ticker={{ summary.ticker }}&status=open">findings for {{ summary.ticker }}</a> &middot;
  <a href="/t/{{ summary.ticker }}">metrics for {{ summary.ticker }}</a>
</footer>

</body>
</html>
