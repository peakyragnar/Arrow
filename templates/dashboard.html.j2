<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Arrow · {{ ticker }}</title>
  <link rel="stylesheet" href="/static/dashboard.css">
</head>
<body>

<header class="topbar">
  <div class="brand">Arrow</div>
  <form class="ticker-select" method="get" action="/">
    <label for="ticker-dropdown">Ticker:</label>
    <select id="ticker-dropdown" onchange="window.location.href = '/t/' + this.value;">
      {% for t in tickers %}
        <option value="{{ t }}" {% if t == ticker %}selected{% endif %}>{{ t }}</option>
      {% endfor %}
    </select>
  </form>
  <div class="meta">
    <span class="period">Latest: {{ latest_period }}</span>
    <span class="flags">
      flags:
      <span class="flag-unresolved">{{ flag_counts.unresolved }} unresolved</span> ·
      <span class="flag-accepted">{{ flag_counts.accepted }} accepted</span>
    </span>
  </div>
</header>

<main>
  <table class="dashboard">
    <thead>
      <tr>
        <th class="metric-name">Metric</th>
        {% for h in headers %}
          {% set is_last_fy = loop.index0 == (n_fy - 1) %}
          {% set is_ttm     = loop.index0 == n_fy %}
          {% set is_first_q = loop.index0 == n_fy + 1 %}
          <th class="
            {% if is_ttm %}ttm-col{% endif %}
            {% if is_first_q %}first-q{% endif %}
            {% if is_last_fy %}last-fy{% endif %}
          ">
            <div class="hdr">
              {% if h.date %}<div class="hdr-date">{{ h.date }}</div>{% endif %}
              <div class="hdr-main">{{ h.main }}</div>
              {% if h.sub %}<div class="hdr-sub">{{ h.sub }}</div>{% endif %}
            </div>
          </th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in rows %}
        <tr class="{% if row.is_change %}change-row{% endif %}">
          <td class="metric-name" {% if row.tooltip %}title="{{ row.tooltip }}"{% endif %}>{{ row.name }}</td>
          {% for cell in row.cells %}
            {% set is_ttm     = loop.index0 == n_fy %}
            {% set is_first_q = loop.index0 == n_fy + 1 %}
            {% set is_last_fy = loop.index0 == (n_fy - 1) %}
            <td class="cell {{ cell[1] }}
              {% if is_ttm %}ttm-col{% endif %}
              {% if is_first_q %}first-q{% endif %}
              {% if is_last_fy %}last-fy{% endif %}
            " title="{{ cell[2] }}">{{ cell[0] }}</td>
          {% endfor %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
</main>

<footer class="bottom">
  <a href="/t/{{ ticker }}/raw">raw JSON</a>
  &middot;
  <a href="/health">health</a>
  &middot;
  <span class="audit-note">Hover cell → period details · ← / → arrows scroll horizontally (Shift+arrow = faster)</span>
</footer>

<script>
  // Keyboard navigation: arrow keys scroll the table horizontally and
  // vertically so you don't need to reach for the scrollbar. Shift
  // multiplies the step. Esc focuses the table (useful after clicking
  // the ticker dropdown).
  (function() {
    const m = document.querySelector('main');
    if (!m) return;
    const STEP_X = 120;
    const STEP_Y = 60;
    document.addEventListener('keydown', function(e) {
      // Ignore when focus is in a form control (dropdown, etc.)
      const t = e.target;
      if (t && (t.tagName === 'SELECT' || t.tagName === 'INPUT' || t.tagName === 'TEXTAREA')) return;
      const mult = e.shiftKey ? 3 : 1;
      let handled = true;
      switch (e.key) {
        case 'ArrowLeft':  m.scrollLeft -= STEP_X * mult; break;
        case 'ArrowRight': m.scrollLeft += STEP_X * mult; break;
        case 'ArrowUp':    m.scrollTop  -= STEP_Y * mult; break;
        case 'ArrowDown':  m.scrollTop  += STEP_Y * mult; break;
        case 'Home':       m.scrollLeft = 0; break;
        case 'End':        m.scrollLeft = m.scrollWidth; break;
        default: handled = false;
      }
      if (handled) e.preventDefault();
    });
  })();
</script>

</body>
</html>
