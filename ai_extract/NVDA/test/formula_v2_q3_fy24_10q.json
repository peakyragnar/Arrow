{
  "ticker": "NVDA",
  "reporting_unit": "Filing reports in USD millions. All monetary values multiplied by 1,000,000 to convert to raw dollars. Share counts reported in millions and multiplied by 1,000,000 to convert to raw count.",
  "company_mapping": {
    "revenue": "us-gaap:Revenues \u2014 labeled Revenue on the income statement. Maps directly to total company revenue.",
    "cogs": "us-gaap:CostOfRevenue \u2014 labeled Cost of revenue on the income statement.",
    "gross_profit": "us-gaap:GrossProfit \u2014 labeled Gross profit on the income statement. Explicitly reported as Revenue minus Cost of revenue.",
    "operating_income": "us-gaap:OperatingIncomeLoss \u2014 labeled Operating income on the income statement.",
    "pretax_income": "us-gaap:IncomeLossFromContinuingOperationsBeforeIncomeTaxesExtraordinaryItemsNoncontrollingInterest \u2014 labeled Income before income tax.",
    "income_tax_expense": "us-gaap:IncomeTaxExpenseBenefit \u2014 labeled Income tax expense (benefit). Positive = expense, negative = benefit.",
    "net_income": "us-gaap:NetIncomeLoss \u2014 labeled Net income on the income statement. Confirmed to match the CFO reconciliation starting line on the cash flow statement. No NCI; NVDA is fully consolidated with no noncontrolling interest.",
    "interest_expense": "us-gaap:InterestExpense \u2014 labeled Interest expense on the income statement. This is gross interest expense disclosed separately from interest income. The filing reports Interest income and Interest expense as separate line items under Other income (expense), net, so gross interest expense is directly available. Normalized as a negative number per policy.",
    "sbc": "us-gaap:ShareBasedCompensation \u2014 labeled Stock-based compensation expense in the operating section of the cash flow statement. Used as total-company SBC source of truth.",
    "dna": "us-gaap:DepreciationDepletionAndAmortization \u2014 labeled Depreciation and amortization in the operating section of the cash flow statement. This is the single D&A addback line; no separate amortization line exists.",
    "diluted_shares": "us-gaap:WeightedAverageNumberOfDilutedSharesOutstanding \u2014 labeled Diluted weighted average shares on the income statement. Converted from millions to raw count.",
    "cash": "us-gaap:CashAndCashEquivalentsAtCarryingValue \u2014 labeled Cash and cash equivalents on the balance sheet. Confirmed equal to CashCashEquivalentsRestrictedCashAndRestrictedCashEquivalents per xbrl_not_on_statement (no restricted cash separately disclosed).",
    "short_term_investments": "us-gaap:MarketableSecuritiesCurrent \u2014 labeled Marketable securities on the balance sheet under current assets.",
    "accounts_receivable": "us-gaap:AccountsReceivableNetCurrent \u2014 labeled Accounts receivable, net on the balance sheet. Pure trade AR.",
    "inventory": "us-gaap:InventoryNet \u2014 labeled Inventories on the balance sheet.",
    "accounts_payable": "us-gaap:AccountsPayableCurrent \u2014 labeled Accounts payable on the balance sheet. Separately reported from Accrued and other current liabilities, so no breakout required.",
    "total_assets": "us-gaap:Assets \u2014 labeled Total assets on the balance sheet.",
    "equity": "us-gaap:StockholdersEquity \u2014 labeled Total shareholders equity on the balance sheet. NVDA has no noncontrolling interest; this is the full equity figure.",
    "short_term_debt": "us-gaap:DebtCurrent \u2014 labeled Short-term debt on the balance sheet. Includes current portion of long-term debt.",
    "long_term_debt": "us-gaap:LongTermDebtNoncurrent \u2014 labeled Long-term debt on the balance sheet.",
    "operating_lease_liabilities": "Current portion: not separately disclosed on the face of the balance sheet \u2014 it is embedded within Accrued and other current liabilities (us-gaap:AccruedLiabilitiesCurrent). Non-current portion: us-gaap:OperatingLeaseLiabilityNoncurrent labeled Long-term operating lease liabilities. For total operating lease liabilities, the current portion must be sourced from the Leases note. The XBRL data does not provide us-gaap:OperatingLeaseLiabilityCurrent as a separate tagged value on the balance sheet face. The supplemental CF discloses OperatingLeasePayments but not the current liability balance. Per the balance sheet formula, Total current liabilities = Accounts payable + Accrued and other current liabilities + Short-term debt, meaning the current operating lease liability is embedded in Accrued and other current liabilities and is not separately extractable from this filing data. Therefore, total operating lease liabilities = non-current only (Long-term operating lease liabilities) as the floor, with a note that current portion is embedded in accrued liabilities and cannot be separately broken out from this extraction.",
    "cfo": "us-gaap:NetCashProvidedByUsedInOperatingActivities \u2014 labeled Net cash provided by operating activities on the cash flow statement.",
    "capex": "us-gaap:PaymentsToAcquireProductiveAssets \u2014 labeled Purchases related to property and equipment and intangible assets on the cash flow statement. Note this includes both PP&E and intangible asset purchases combined. Normalized as a negative number per policy.",
    "acquisitions": "us-gaap:PaymentsToAcquireBusinessesNetOfCashAcquired \u2014 labeled Acquisitions, net of cash acquired on the cash flow statement. Normalized as a negative number per policy.",
    "rd_expense": "us-gaap:ResearchAndDevelopmentExpense \u2014 labeled Research and development on the income statement under operating expenses.",
    "interest_income": "us-gaap:InvestmentIncomeInterest \u2014 labeled Interest income on the income statement. Needed for Unlevered FCF and interest coverage context.",
    "cash_paid_for_interest": "Not separately disclosed in the supplemental cash flow disclosures in this filing. Only cash paid for income taxes (us-gaap:IncomeTaxesPaidNet) is disclosed as a supplemental item. For Metric 21 (Unlevered FCF), approximate with income-statement gross interest expense per the metric formula fallback rule.",
    "current_operating_lease_liabilities": "Not separately tagged on the face of the balance sheet. Embedded within us-gaap:AccruedLiabilitiesCurrent. Cannot be isolated from this extraction. Set to null pending note disclosure.",
    "noncurrent_operating_lease_liabilities": "us-gaap:OperatingLeaseLiabilityNoncurrent \u2014 labeled Long-term operating lease liabilities on the balance sheet.",
