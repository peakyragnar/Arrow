# Arrow environment — copy to `.env` and fill in real values. Never commit `.env`.

# Postgres (local Homebrew postgresql@16 on port 5433 to avoid clash with @14 on 5432)
DATABASE_URL=postgresql://arrow:arrow@localhost:5433/arrow

# FMP API key — request one at https://site.financialmodelingprep.com/
FMP_API_KEY=your-key-here
